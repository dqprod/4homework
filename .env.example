# Storage
STORAGE_BACKEND=local

# Storage (local in MVP; switch to Supabase Storage URL in Phase 2)
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage

# AI (mock in MVP; set AI_BACKEND=real + NVIDIA_API_KEY to use real)
AI_BACKEND=mock
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.2-nvlm-vision-90b
NVIDIA_TIMEOUT=60
NVIDIA_MAX_RETRIES=2

# App
APP_HOST=127.0.0.1
APP_PORT=8000

# Ebbinghaus intervals (days). Per md spec: [1, 2, 4, 7, 15, 30]
EBBINGHAUS_INTERVALS=1,2,4,7,15,30
EBBINGHAUS_INITIAL_INTERVAL=1
